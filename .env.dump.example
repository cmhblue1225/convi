# 편의점 관리 시스템 - 데이터베이스 덤프 설정 예제
# 사용법: 이 파일을 .env.dump로 복사하고 실제 값으로 수정하세요

# Supabase 프로젝트 정보
SUPABASE_PROJECT_ID=your_project_id_here
SUPABASE_DB_PASSWORD=your_database_password_here

# 데이터베이스 연결 정보 (기본값 - 필요시 수정)
SUPABASE_DB_HOST=aws-0-ap-northeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres

# 덤프 출력 설정
DUMP_OUTPUT_DIR=./dumps

# 설정 방법:
# 1. cp .env.dump.example .env.dump
# 2. .env.dump 파일의 SUPABASE_PROJECT_ID와 SUPABASE_DB_PASSWORD 수정
# 3. ./scripts/dump_database.sh 실행